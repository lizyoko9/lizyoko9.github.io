---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="文章 | Lizlog" description="所有文章归档">
    <section>
        <!-- 页面标题 -->
        <div class="mb-10">
            <h1 class="text-3xl md:text-4xl font-display font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
                所有文章
            </h1>
            <p class="mt-2 text-slate-500 dark:text-slate-400">
                共 {posts.length} 篇文章
            </p>
            <div class="mt-4 h-1 w-16 bg-gradient-to-r from-primary-500 to-primary-300 rounded-full"></div>
        </div>

        <div class="grid gap-6">
            {posts.map((post, index) => (
                <article class="group relative bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200/60 dark:border-slate-800/60 overflow-hidden card-hover animate-fade-in-up" style={`animation-delay: ${0.05 + index * 0.06}s`}>
                    <!-- 左侧渐变装饰条 -->
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-primary-500 via-sky-400 to-cyan-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                    <div class="p-6 md:p-8">
                        <div class="flex items-center gap-3 mb-3">
                            <span class="tag text-xs">
                                {post.data.pubDate.toLocaleDateString('zh-CN', {
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric',
                                })}
                            </span>
                            <span class="text-xs text-slate-400 dark:text-slate-500 font-mono">
                                {post.id.split('/')[0]}
                            </span>
                        </div>

                        <h2 class="text-xl md:text-2xl font-bold mb-2">
                            <a href={`/blog/${post.id}/`} class="text-slate-900 dark:text-slate-100 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                                {post.data.title}
                            </a>
                        </h2>

                        <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
                            {post.data.description}
                        </p>

                        <div class="mt-4">
                            <a href={`/blog/${post.id}/`} class="link-underline text-primary-600 dark:text-primary-400 text-sm font-medium inline-flex items-center gap-1">
                                阅读全文
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
                                    <path d="M5 12h14M12 5l7 7-7 7"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </section>
</Layout>
