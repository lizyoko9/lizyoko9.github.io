---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = Array.from(
    new Set(posts.flatMap((post) => post.data.tags.length ? post.data.tags : [post.id.split('/')[0]]))
).sort((a, b) => a.localeCompare(b));
---

<Layout title="文章 | Lizlog" description="所有文章归档">
    <section>
        <!-- 页面标题 -->
        <div class="mb-10">
            <h1 class="text-3xl md:text-4xl font-display font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
                所有文章
            </h1>
            <p class="mt-2 text-slate-500 dark:text-slate-400">
                共 {posts.length} 篇文章
            </p>
            <div class="mt-4 h-1 w-16 bg-gradient-to-r from-primary-500 to-primary-300 rounded-full"></div>
        </div>

        <div class="mb-8">
            <div class="tag-filter-panel" data-tag-filter-panel>
                <div class="flex flex-wrap gap-2" data-tag-filter>
                    <button type="button" class="tag tag-filter is-active" data-tag="all">全部</button>
                    {allTags.map((tag) => (
                        <button type="button" class="tag tag-filter" data-tag={tag}>{tag}</button>
                    ))}
                </div>
            </div>
            {allTags.length > 6 && (
                <button type="button" class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-primary-600 transition hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300" data-tag-toggle aria-expanded="false">
                    <span data-tag-toggle-label>展开标签</span>
                    <svg class="h-3.5 w-3.5 transition-transform" data-tag-toggle-icon xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="m6 9 6 6 6-6" />
                    </svg>
                </button>
            )}
        </div>

        <p class="mb-5 hidden text-sm text-slate-500 dark:text-slate-400" data-empty-state>
            暂无对应标签的文章。
        </p>

        <div class="grid gap-6" data-post-list>
            {posts.map((post, index) => {
                const tags = post.data.tags.length ? post.data.tags : [post.id.split('/')[0]];

                return (
                <article data-post-card data-tags={JSON.stringify(tags)} class="group relative bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200/60 dark:border-slate-800/60 overflow-hidden card-hover animate-fade-in-up" style={`animation-delay: ${0.05 + index * 0.06}s`}>
                    <!-- 左侧渐变装饰条 -->
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-primary-500 via-sky-400 to-cyan-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                    <div class="p-6 md:p-8">
                        <div class="flex items-center gap-3 mb-3">
                            <span class="tag text-xs">
                                {post.data.pubDate.toLocaleDateString('zh-CN', {
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric',
                                })}
                            </span>
                            {tags.slice(0, 4).map((tag) => (
                                <span class="font-mono text-xs text-primary-600 dark:text-primary-400 rounded-full bg-primary-50 px-2.5 py-1 dark:bg-slate-800">
                                    {tag}
                                </span>
                            ))}
                        </div>

                        <h2 class="text-xl md:text-2xl font-bold mb-2">
                            <a href={`/blog/${post.id}/`} class="text-slate-900 dark:text-slate-100 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                                {post.data.title}
                            </a>
                        </h2>

                        <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
                            {post.data.description}
                        </p>

                        <div class="mt-4">
                            <a href={`/blog/${post.id}/`} class="link-underline text-primary-600 dark:text-primary-400 text-sm font-medium inline-flex items-center gap-1">
                                阅读全文
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
                                    <path d="M5 12h14M12 5l7 7-7 7"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </article>
                );
            })}
        </div>
    </section>
</Layout>

<script>
    const filterRoot = document.querySelector('[data-tag-filter]');
    const filterPanel = document.querySelector<HTMLElement>('[data-tag-filter-panel]');
    const toggleButton = document.querySelector<HTMLButtonElement>('[data-tag-toggle]');
    const toggleLabel = document.querySelector<HTMLElement>('[data-tag-toggle-label]');
    const toggleIcon = document.querySelector<SVGElement>('[data-tag-toggle-icon]');
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tag]'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-post-card]'));
    const emptyState = document.querySelector<HTMLElement>('[data-empty-state]');

    const applyFilter = (tag: string) => {
        let visibleCount = 0;

        cards.forEach((card) => {
            const tags = JSON.parse(card.dataset.tags ?? '[]') as string[];
            const visible = tag === 'all' || tags.includes(tag);

            card.toggleAttribute('hidden', !visible);
            if (visible) visibleCount += 1;
        });

        buttons.forEach((button) => {
            const active = button.dataset.tag === tag;
            button.classList.toggle('is-active', active);
            button.setAttribute('aria-pressed', String(active));
        });

        if (emptyState) {
            emptyState.classList.toggle('hidden', visibleCount > 0);
        }
    };

    filterRoot?.addEventListener('click', (event) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-tag]');
        if (!button?.dataset.tag) return;

        applyFilter(button.dataset.tag);
    });

    toggleButton?.addEventListener('click', () => {
        const expanded = filterPanel?.classList.toggle('is-expanded') ?? false;

        toggleButton.setAttribute('aria-expanded', String(expanded));
        if (toggleLabel) toggleLabel.textContent = expanded ? '收起标签' : '展开标签';
        toggleIcon?.classList.toggle('rotate-180', expanded);
    });

    applyFilter('all');
</script>
