---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// 仅展示 h2 和 h3，避免层级过深
const toc = headings
    .filter((h) => h.depth > 1 && h.depth <= 3)
    .map((heading) => ({
        ...heading,
        anchor: ('slug' in heading ? heading.slug : undefined) ?? ('id' in heading ? heading.id : undefined),
    }))
    .filter((heading) => heading.anchor);
---

<nav class="toc-container" aria-label="目录导航">
    {toc.length > 0 ? (
        <ul class="space-y-0.5 text-sm">
            {toc.map((heading) => (
                <li class={`${heading.depth === 3 ? 'ml-4' : ''}`}>
                    <a
                        href={`#${heading.anchor}`}
                        class="group flex items-center gap-2 py-1.5 pl-3 pr-2 rounded-r-lg text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-all duration-200 border-l-2 border-transparent"
                    >
                        <!-- 活跃指示圆点 -->
                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-slate-600 group-hover:bg-primary-400 transition-colors duration-200 shrink-0"></span>
                        <span class="truncate">{heading.text}</span>
                    </a>
                </li>
            ))}
        </ul>
    ) : (
        <p class="text-sm text-slate-400 dark:text-slate-500 italic">本文暂无目录</p>
    )}
</nav>

<script>
    // 滚动高亮：带圆点指示器
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            const id = entry.target.getAttribute('id');
            const link = document.querySelector(`.toc-container a[href="#${id}"]`);
            if (!link) return;

            if (entry.isIntersecting && entry.intersectionRatio > 0) {
                // 重置所有链接
                document.querySelectorAll('.toc-container a').forEach((a) => {
                    a.classList.remove(
                        'text-primary-700', 'dark:text-primary-300', 'font-semibold',
                        'border-primary-500', 'bg-primary-50', 'dark:bg-primary-950/30'
                    );
                    a.classList.add('text-slate-500', 'dark:text-slate-400', 'border-transparent');
                    // 重置圆点
                    const dot = a.querySelector('span');
                    if (dot) {
                        dot.classList.remove('bg-primary-500', 'w-2', 'h-2');
                        dot.classList.add('bg-slate-300', 'dark:bg-slate-600', 'w-1.5', 'h-1.5');
                    }
                });

                // 高亮当前链接
                link.classList.remove('text-slate-500', 'dark:text-slate-400', 'border-transparent');
                link.classList.add(
                    'text-primary-700', 'dark:text-primary-300', 'font-semibold',
                    'border-primary-500', 'bg-primary-50/50', 'dark:bg-primary-950/20'
                );
                // 高亮圆点
                const dot = link.querySelector('span');
                if (dot) {
                    dot.classList.remove('bg-slate-300', 'dark:bg-slate-600', 'w-1.5', 'h-1.5');
                    dot.classList.add('bg-primary-500', 'w-2', 'h-2');
                }
            }
        });
    }, {
        rootMargin: '-80px 0px -60% 0px',
        threshold: 0.1,
    });

    // 监听所有 h2, h3
    document.querySelectorAll('article h2[id], article h3[id]').forEach((h) => {
        observer.observe(h);
    });
</script>
